# ============================================================================
# RistoBrain — Variabili d'ambiente PRODUZIONE
# ============================================================================
# 1. Copia questo file: cp .env.production.example .env
# 2. Sostituisci TUTTI i valori con quelli reali
# 3. NON committare mai il file .env su Git!
# ============================================================================

# ── Dominio pubblico ─────────────────────────────────────────────────────────
DOMAIN=tuodominio.com

# ── GitHub (usato da docker-compose.prod.yml per le immagini) ────────────────
GITHUB_REPOSITORY=tuonomeutente/ristobrain-app
IMAGE_TAG=latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ristobrain
POSTGRES_USER=ristobrain_prod
# !! Genera con: openssl rand -hex 32
POSTGRES_PASSWORD=CAMBIA_QUESTO_CON_PASSWORD_SICURA

# ── Redis ─────────────────────────────────────────────────────────────────────
# !! Genera con: openssl rand -hex 24
REDIS_PASSWORD=CAMBIA_QUESTO_CON_PASSWORD_REDIS

# ── JWT ───────────────────────────────────────────────────────────────────────
# !! Genera con: openssl rand -hex 64   (minimo 64 caratteri)
JWT_SECRET=CAMBIA_QUESTO_CON_SECRET_LUNGHISSIMO_E_CASUALE
JWT_EXPIRES_IN=7d

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://tuodominio.com

# ── Backup ───────────────────────────────────────────────────────────────────
BACKUP_DIR=/opt/ristobrain/backups
BACKUP_RETENTION=30
# Opzionale: upload su S3
# S3_BUCKET=s3://nome-bucket/ristobrain-backups
# AWS_PROFILE=default

# ── Opzionali ─────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# SENTRY_DSN=https://...@sentry.io/...
# STRIPE_SECRET_KEY=sk_live_...
