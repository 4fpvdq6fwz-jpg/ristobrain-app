# ============================================
# RistoBrain + MenuMaster — Environment Variables
# ============================================
# Copia questo file come .env e personalizza i valori

# Database PostgreSQL
DATABASE_URL=postgresql://ristobrain:ristobrain_secret@localhost:5432/ristobrain

# Redis
REDIS_URL=redis://localhost:6379

# JWT - CAMBIA QUESTO IN PRODUZIONE!
JWT_SECRET=change_this_in_production_super_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Upload
UPLOAD_DIR=/tmp/ristobrain-uploads

# Opzionali (produzione)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# OPENAI_API_KEY=sk-...
# SENTRY_DSN=https://...
